---
import "../styles/site.css";

const repoUrl = "https://github.com/jordanchase/lmu-cmsi-3802-homework1";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const asset = (path) => `${baseUrl}${String(path).replace(/^\/+/, "")}`;

const navLinks = [
  { href: "#story", label: "Story" },
  { href: "#examples", label: "Examples" },
  { href: "#developers", label: "Developers" },
  { href: repoUrl, label: "Repo", external: true },
];

const overview = [
  "In an age before silicon-based screens, computation was the craft of scribes, scholars, and quiet thinkers. These were the people who transformed symbols into meaning. Rímere reimagines programming as it might have existed in that world: a language shaped not by modern syntax, but by the cadence and vocabulary of Old English.",
  "Rather than calling functions or executing commands, a programmer in Rímere chants instructions, binds values, and declares truths using words inspired by a time when knowledge was handwritten and computation was an art. By blending historical language with modern programming principles, Rímere invites its users to experience coding as both logic and storytelling.",
  "Rímere is not intended to be a perfectly reconstructed linguistic model of Old English. Instead, it is a thematic programming language that draws from Old English vocabulary and style while remaining readable, teachable, and implementable in a modern compiler project.",
];

const examples = [
  {
    title: "hello.rim",
    code: `sprecan "hātan grētan, Rímere!";`,
  },
  {
    title: "variables.rim",
    code: `bindan x as 5;
bindan y as 10;
sprecan x + y;`,
  },
  {
    title: "if.rim",
    code: `bindan x as 5;
gif x > 3:
  sprecan "big";
elles:
  sprecan "small";
end`,
  },
  {
    title: "function.rim",
    code: `ritan add with a, b:
  cweðan a + b;
end

sprecan add(2, 3);`,
  },
  {
    title: "loop.rim",
    code: `foran i fram 1 to 3:
  sprecan i;
end`,
  },
  {
    title: "wyrd.rim",
    code: `sprecan "wyrd";`,
  },
];

const developers = [
  {
    initials: "JC",
    name: "Jordan Chase",
    photo: "jordanphoto.png",
    bio: "Computer Science @ Loyola Marymount University '27",
  },
  {
    initials: "ML",
    name: "Marleena Limbrick",
    photo: "marleenaphoto.png",
    bio: "Marleena is a third year computer science student who loves Medieval Times and the Ren Faire",
  },
  {
    initials: "VA",
    name: "Vicente Anyaegbu",
    bio: "Computer Science @ Loyola Marymount University '27",
  },
  {
    initials: "AW",
    name: "Audrey Whitney-Miller",
    photo: "audreyphoto.jpeg",
    bio:"Audrey is a computer science student who enjoys web development and her favorite show is BBC Merlin.",
  },
  {
    initials: "R",
    name: "Ray",
    bio: "Computer Science @ Loyola Marymount University '27",
  },
  {
    initials: "T",
    name: "Temi",
    bio: "Computer Science @ Loyola Marymount University '27",
  },
  {
    initials: "AB",
    name: "Anastasia Buzovo",
    bio: "Computer Science @ Loyola Marymount University '27",
  },
];

const featureGroups = [
  {
    title: "Design Goals",
    items: [
      "Create a programming language with a distinctive medieval identity",
      "Make syntax feel literary and narrative rather than purely mechanical",
      "Preserve core programming concepts in a form that is still understandable to modern users",
      "Balance novelty with usability so the language is fun to write and feasible to implement",
      "Explore how theme and syntax can shape the programmer’s experience",
    ],
  },
  {
    title: "Features",
    items: [
      "Readable, narrative-style code",
      "Variable binding, arithmetic expressions, conditionals, loops, and functions",
      "Booleans, numbers, and strings",
      "A minimal punctuation philosophy",
    ],
  },
  {
    title: "Static Semantics",
    items: [
      "Variables must be declared before use",
      "Variables cannot be redeclared in the same scope",
      "Function calls must use the correct number of arguments",
      "Arithmetic operations require numbers",
      "Logical operations require booleans",
      "If and while conditions must be boolean",
      "Break statements only appear inside loops",
      "Return statements only appear inside functions",
    ],
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Rímere is a medieval-themed programming language inspired by Old English vocabulary and compiled to JavaScript."
    />
    <link rel="icon" type="image/svg+xml" href={asset("favicon.svg")} />
    <link rel="icon" href={asset("favicon.ico")} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=MedievalSharp&family=Uncial+Antiqua&display=swap"
      rel="stylesheet"
    />
    <title>Rímere</title>
  </head>
  <body>
    <main class="page-shell">
      <section class="sheet hero-shell" id="top">
        <header class="masthead">
          <div class="crest-row">
            <img
              class="flourish-image flourish-image-left"
              src={asset("left.png")}
              alt=""
              aria-hidden="true"
            />
            <div class="logo-box">
              <img src={asset("rimere-logo.png")} alt="Rímere logo" />
            </div>
            <img
              class="flourish-image flourish-image-right"
              src={asset("right.png")}
              alt=""
              aria-hidden="true"
            />
          </div>

          <p class="hero-kicker">Computing for the Medieval World</p>
          <h1>Rímere</h1>

          <nav class="nav-row" aria-label="Primary">
            {navLinks.map((link) => (
              <a
                href={link.href}
                target={link.external ? "_blank" : undefined}
                rel={link.external ? "noreferrer" : undefined}
              >
                {link.label}
              </a>
            ))}
          </nav>
        </header>
      </section>

      <section class="sheet content-section" id="story">
        <div class="section-heading">
          <p class="eyebrow">Overview</p>
          <h2>Overview</h2>
        </div>
        <div class="story-grid">
          <div class="story-copy">
            {overview.map((paragraph) => <p>{paragraph}</p>)}
          </div>
          <aside class="story-panel">
            <h3>Design Goals</h3>
            <ul>
              <li>Create a programming language with a distinctive medieval identity</li>
              <li>Make syntax feel literary and narrative rather than purely mechanical</li>
              <li>Preserve core programming concepts in a form that is still understandable to modern users</li>
              <li>Balance novelty with usability so the language is fun to write and feasible to implement</li>
            </ul>
            <a class="repo-button" href={repoUrl} target="_blank" rel="noreferrer">
              View the Compiler Repo
            </a>
          </aside>
        </div>
      </section>

      <section class="sheet content-section" id="examples">
        <div class="section-heading">
          <p class="eyebrow">Examples</p>
          <h2>Example Programs</h2>
        </div>
        <div class="example-grid">
          {examples.map((example) => (
            <article class="example-card">
              <div class="card-heading">
                <h3>{example.title}</h3>
              </div>
              <pre><code>{example.code}</code></pre>
            </article>
          ))}
        </div>
      </section>

      <section class="sheet content-section" id="developers">
        <div class="section-heading">
          <p class="eyebrow">Developers</p>
          <h2>Authors</h2>
        </div>
        <div class="developer-layout">
          <div class="developer-list">
            {developers.map((developer) => (
              <article class="developer-row">
                <div class="developer-mark">
                  {developer.photo ? (
                    <img src={asset(developer.photo)} alt={developer.name} />
                  ) : (
                    <span>{developer.initials}</span>
                  )}
                </div>
                <div class="developer-copy">
                  <h3>{developer.name}</h3>
                  <p>{developer.bio}</p>
                </div>
              </article>
            ))}
          </div>

          <aside class="features-panel">
            <div class="section-heading section-heading-compact">
              <p class="eyebrow">Reference</p>
              <h2>Features</h2>
            </div>
            <div class="feature-sections">
              {featureGroups.map((group) => (
                <section class="feature-block">
                  <h3>{group.title}</h3>
                  <ul>
                    {group.items.map((item) => <li>{item}</li>)}
                  </ul>
                </section>
              ))}
            </div>
          </aside>
        </div>
      </section>
    </main>

    <audio
      id="rimere-bg-audio"
      src={asset("backgroundmusic.mp3")}
      preload="auto"
      playsinline
      loop
    ></audio>
    <button
      id="rimere-audio-toggle"
      class="audio-toggle"
      type="button"
      aria-label="Toggle background music mute"
      aria-pressed="false"
    >
      Mute
    </button>

    <script is:inline>
      (() => {
        const STORAGE_KEY = "rimere:bg-audio-muted";
        const audio = document.getElementById("rimere-bg-audio");
        const toggle = document.getElementById("rimere-audio-toggle");

        if (!(audio instanceof HTMLAudioElement) || !(toggle instanceof HTMLButtonElement)) return;

        let storedMuted = null;
        try {
          storedMuted = localStorage.getItem(STORAGE_KEY);
        } catch {
          storedMuted = null;
        }
        let muted = storedMuted === null ? false : storedMuted === "true";

        audio.volume = 0.35;
        audio.muted = muted;

        let started = !audio.paused;

        const syncToggle = () => {
          started = started || !audio.paused;
          toggle.textContent = started ? (muted ? "Unmute" : "Mute") : "Play";
          toggle.setAttribute("aria-pressed", started ? String(muted) : "false");
          toggle.setAttribute(
            "aria-label",
            started ? "Toggle background music mute" : "Play background music"
          );
        };

        const tryPlay = () => {
          try {
            const playResult = audio.play();
            if (playResult && typeof playResult.then === "function") {
              return playResult.then(
                () => {
                  started = true;
                  syncToggle();
                  return true;
                },
                () => false
              );
            }
            started = true;
            syncToggle();
            return Promise.resolve(true);
          } catch {
            return Promise.resolve(false);
          }
        };

        const ensurePlaying = () => (audio.paused ? tryPlay() : Promise.resolve(true));

        syncToggle();

        audio.addEventListener("playing", () => {
          started = true;
          syncToggle();
        });
        audio.addEventListener("pause", () => {
          syncToggle();
        });

        let waitingForGesture = false;
        const armGesturePlayback = () => {
          if (waitingForGesture) return;
          waitingForGesture = true;

          const onGesture = () => {
            waitingForGesture = false;
            // Call play() synchronously inside the gesture handler for maximum browser compatibility.
            void tryPlay();
          };

          document.addEventListener("click", onGesture, { capture: true, once: true });
          document.addEventListener("touchend", onGesture, { capture: true, once: true, passive: true });
          document.addEventListener("pointerup", onGesture, { capture: true, once: true });
          document.addEventListener("mouseup", onGesture, { capture: true, once: true });
          document.addEventListener("mousedown", onGesture, { capture: true, once: true });
          document.addEventListener("keydown", onGesture, { capture: true, once: true });
        };

        // Attempt to start playback immediately; if blocked by autoplay policies, wait for first user gesture.
        ensurePlaying().then((started) => {
          if (!started) armGesturePlayback();
          syncToggle();
        });

        toggle.addEventListener("click", async () => {
          if (audio.paused) {
            const startedNow = await ensurePlaying();
            if (!startedNow) armGesturePlayback();
            syncToggle();
            return;
          }

          muted = !muted;
          try {
            localStorage.setItem(STORAGE_KEY, String(muted));
          } catch {
            // Ignore storage failures (e.g., private browsing restrictions).
          }
          audio.muted = muted;
          syncToggle();

          if (!muted) {
            const started = await ensurePlaying();
            if (!started) armGesturePlayback();
          }
        });
      })();
    </script>
  </body>
</html>
